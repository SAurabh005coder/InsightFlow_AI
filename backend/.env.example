# Database Configuration
# Replace YOUR_POSTGRES_PASSWORD with your actual local PostgreSQL password
DATABASE_URL=postgresql://postgres:YOUR_POSTGRES_PASSWORD@localhost:5432/insightflow_ai

# AI Assistant Configuration
# AI_PROVIDER can be "mock" (default, runs offline), "gemini", or "openai"
AI_PROVIDER=mock
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
